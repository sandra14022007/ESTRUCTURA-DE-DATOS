    double v;
    while (true) {
        cout << prompt;
        if (cin >> v && v >= 0.0 && v <= 10.0) { limpiarBuffer(); return v; }
        cout << "  [!] Ingrese un valor entre 0 y 10.\n";
        cin.clear(); limpiarBuffer();
    }
}

bool preguntarRepetir(const string& accion) {
    while (true) {
        string r = leerLinea("  Desea " + accion + " nuevamente? (s/n): ");
        if (r == "s" || r == "S") return true;
        if (r == "n" || r == "N") return false;
        cout << "  [!] Responda s o n.\n";
    }
}

// Validacion basica de formato dd/mm/aaaa
bool validarFecha(const string& f) {
    if ((int)f.size() != 10 || f[2] != '/' || f[5] != '/') return false;
    int d = atoi(f.substr(0,2).c_str());
    int m = atoi(f.substr(3,2).c_str());
    int a = atoi(f.substr(6,4).c_str());
    return (d >= 1 && d <= 31 && m >= 1 && m <= 12 && a >= 1900 && a <= 2100);
}

