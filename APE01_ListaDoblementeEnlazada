#include <iostream>
#include <string>
#include <limits>
using namespace std;

template <typename T>
struct NodoDoble {
    T info;
    NodoDoble<T>* anterior;
    NodoDoble<T>* siguiente;

    NodoDoble(T valor) : info(valor), anterior(nullptr), siguiente(nullptr) {}
};

template <typename T>
class ListaDoble {
private:
    NodoDoble<T>* primero;
    NodoDoble<T>* ultimo;

public:
    ListaDoble() : primero(nullptr), ultimo(nullptr) {}

    ~ListaDoble() {
        NodoDoble<T>* actual = primero;
        while (actual != nullptr) {
            NodoDoble<T>* sig = actual->siguiente;
            delete actual;
            actual = sig;
        }
        primero = ultimo = nullptr;
    }

    void insertarInicio(T valor) {
        NodoDoble<T>* nuevo = new NodoDoble<T>(valor);
        if (primero == nullptr) {
            primero = ultimo = nuevo;
        } else {
            nuevo->siguiente = primero;
            primero->anterior = nuevo;
            primero = nuevo;
        }
    }

    void insertarFinal(T valor) {
        NodoDoble<T>* nuevo = new NodoDoble<T>(valor);
        if (ultimo == nullptr) {
            primero = ultimo = nuevo;
        } else {
            nuevo->anterior = ultimo;
            ultimo->siguiente = nuevo;
            ultimo = nuevo;
        }
    }

    bool buscar(T valor) const {
        NodoDoble<T>* actual = primero;
        while (actual != nullptr) {
            if (actual->info == valor) return true;
            actual = actual->siguiente;
        }
        return false;
    }

    bool eliminar(T valor) {
        if (primero == nullptr) return false;
        NodoDoble<T>* actual = primero;
        while (actual != nullptr) {
            if (actual->info == valor) {
                if (actual->anterior != nullptr)
                    actual->anterior->siguiente = actual->siguiente;
                else
                    primero = actual->siguiente;
                if (actual->siguiente != nullptr)
                    actual->siguiente->anterior = actual->anterior;
                else
                    ultimo = actual->anterior;
                delete actual;
                return true;
            }
            actual = actual->siguiente;
        }
        return false;
    }

    void mostrarAdelante() const {
        if (primero == nullptr) {
            cout << "  [Lista vacia]" << endl;
            return;
        }
        cout << "  nullptr <-> ";
        NodoDoble<T>* actual = primero;
        while (actual != nullptr) {
            cout << actual->info;
            if (actual->siguiente != nullptr) cout << " <-> ";
            actual = actual->siguiente;
        }
        cout << " <-> nullptr" << endl;
    }

    void mostrarAtras() const {
        if (ultimo == nullptr) {
            cout << "  [Lista vacia]" << endl;
            return;
        }
        cout << "  nullptr <-> ";
        NodoDoble<T>* actual = ultimo;
        while (actual != nullptr) {
            cout << actual->info;
            if (actual->anterior != nullptr) cout << " <-> ";
            actual = actual->anterior;
        }
        cout << " <-> nullptr" << endl;
    }

    void consultarExtremos() const {
        if (primero == nullptr)
            cout << "  Lista vacia." << endl;
        else
            cout << "  Primero: " << primero->info << "  |  Ultimo: " << ultimo->info << endl;
    }

    void vaciar() {
        NodoDoble<T>* actual = primero;
        while (actual != nullptr) {
            NodoDoble<T>* sig = actual->siguiente;
            delete actual;
            actual = sig;
        }
        primero = ultimo = nullptr;
    }

    bool estaVacia() const {
        return primero == nullptr;
    }
};

void limpiarPantalla() {
    system("cls");
}

void pausar() {
    cout << "\n  Presiona Enter para continuar...";
    cin.ignore(numeric_limits<streamsize>::max(), '\n');
    cin.get();
}

void linea() {
    cout << "  ============================================" << endl;
}

void menuInt() {
    ListaDoble<int> lista;
    int opcion, valor;

    do {
        limpiarPantalla();
        linea();
        cout << "   LISTA DOBLEMENTE ENLAZADA" << endl;
        linea();
        cout << endl;
        cout << "  1. Insertar al final" << endl;
        cout << "  2. Insertar al inicio" << endl;
        cout << "  3. Buscar elemento" << endl;
        cout << "  4. Eliminar elemento" << endl;
        cout << "  5. Mostrar adelante" << endl;
        cout << "  6. Mostrar atras" << endl;
        cout << "  7. Ver primero y ultimo" << endl;
        cout << "  8. Vaciar lista" << endl;
        cout << "  0. Volver al menu principal" << endl;
        linea();
        cout << "  Opcion: ";
        cin >> opcion;

        if (cin.fail()) {
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout << "  >> Opcion invalida." << endl;
            pausar();
            continue;
        }

        switch (opcion) {
            case 1:
                cout << "  Valor: ";
                cin >> valor;
                lista.insertarFinal(valor);
                cout << "  >> " << valor << " insertado al final." << endl;
                pausar();
                break;
            case 2:
                cout << "  Valor: ";
                cin >> valor;
                lista.insertarInicio(valor);
                cout << "  >> " << valor << " insertado al inicio." << endl;
                pausar();
                break;
            case 3:
                cout << "  Valor a buscar: ";
                cin >> valor;
                if (lista.buscar(valor))
                    cout << "  >> ENCONTRADO." << endl;
                else
                    cout << "  >> NO encontrado." << endl;
                pausar();
                break;
            case 4:
                cout << "  Valor a eliminar: ";
                cin >> valor;
                if (lista.eliminar(valor))
                    cout << "  >> Eliminado." << endl;
                else
                    cout << "  >> No encontrado." << endl;
                pausar();
                break;
            case 5:
                cout << "\n  Lista (inicio -> fin):" << endl;
                lista.mostrarAdelante();
                pausar();
                break;
            case 6:
                cout << "\n  Lista (fin -> inicio):" << endl;
                lista.mostrarAtras();
                pausar();
                break;
            case 7:
                lista.consultarExtremos();
                pausar();
                break;
            case 8:
                lista.vaciar();
                cout << "  >> Lista vaciada." << endl;
                pausar();
                break;
            case 0:
                break;
            default:
                cout << "  >> Opcion invalida." << endl;
                pausar();
        }

    } while (opcion != 0);
}

