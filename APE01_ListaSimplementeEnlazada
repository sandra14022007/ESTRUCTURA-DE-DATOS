#include <iostream>
#include <string>
using namespace std;

// ================= NODO SIMPLE =================
template <typename T>
struct Nodo{
    T dato;
    Nodo<T>* siguiente;
};

// ================= LISTA SIMPLE =================
template <typename T>
class ListaSimple{

private:
    Nodo<T>* primero;
    Nodo<T>* ultimo;

public:

    ListaSimple(){
        primero = NULL;
        ultimo = NULL;
    }

    void insertarInicio(T valor){
        Nodo<T>* nuevo = new Nodo<T>;
        nuevo->dato = valor;
        nuevo->siguiente = primero;

        if(primero == NULL)
            ultimo = nuevo;

        primero = nuevo;
    }

    void insertarFinal(T valor){
        Nodo<T>* nuevo = new Nodo<T>;
        nuevo->dato = valor;
        nuevo->siguiente = NULL;

        if(ultimo != NULL)
            ultimo->siguiente = nuevo;
        else
            primero = nuevo;

        ultimo = nuevo;
    }

    void buscar(T valor){
        Nodo<T>* temp = primero;

        while(temp != NULL){
            if(temp->dato == valor){
                cout << "Elemento encontrado\n";
                return;
            }
            temp = temp->siguiente;
        }
        cout << "Elemento no encontrado\n";
    }

    void eliminar(T valor){
        Nodo<T>* temp = primero;
        Nodo<T>* anterior = NULL;

        while(temp != NULL && temp->dato != valor){
            anterior = temp;
            temp = temp->siguiente;
        }

        if(temp == NULL){
            cout << "Elemento no encontrado\n";
            return;
        }

        if(temp == primero){
            primero = primero->siguiente;
            if(primero == NULL)
                ultimo = NULL;
        }
        else{
            anterior->siguiente = temp->siguiente;
            if(temp == ultimo)
                ultimo = anterior;
        }

        delete temp;
        cout << "Elemento eliminado\n";
    }

    void mostrar(){
        Nodo<T>* temp = primero;
        while(temp != NULL){
            cout << temp->dato << " -> ";
            temp = temp->siguiente;
        }
        cout << "NULL\n";
    }

    void primeroElemento(){
        if(primero != NULL)
            cout << "Primer elemento: " << primero->dato << endl;
        else
            cout << "Lista vacia\n";
    }

    void ultimoElemento(){
        if(ultimo != NULL)
            cout << "Ultimo elemento: " << ultimo->dato << endl;
        else
            cout << "Lista vacia\n";
    }
};

// ================= MENÚ =================
template <typename T>
void menuLista(){

    ListaSimple<T> lista;
    int opcion;
    T valor;

    do{
        cout << "\n--- LISTA SIMPLEMENTE ENLAZADA ---\n";
        cout << "1. Insertar al inicio\n";
        cout << "2. Insertar al final\n";
        cout << "3. Buscar elemento\n";
        cout << "4. Eliminar elemento\n";
        cout << "5. Mostrar lista\n";
        cout << "6. Consultar primero\n";
        cout << "7. Consultar ultimo\n";
        cout << "8. Salir\n";

        cout << "Opcion: ";
        cin >> opcion;

        if(cin.fail()){
            cin.clear();
            cin.ignore(1000, '\n');
            cout << "Entrada invalida\n";
            continue;
        }

        switch(opcion){

        case 1:
            cout << "Valor: ";
            cin >> valor;
            lista.insertarInicio(valor);
            break;

        case 2:
            cout << "Valor: ";
            cin >> valor;
            lista.insertarFinal(valor);
            break;

        case 3:
            cout << "Buscar valor: ";
            cin >> valor;
            lista.buscar(valor);
            break;

        case 4:
            cout << "Eliminar valor: ";
            cin >> valor;
            lista.eliminar(valor);
            break;

        case 5:
            lista.mostrar();
            break;

        case 6:
            lista.primeroElemento();
            break;

        case 7:
            lista.ultimoElemento();
            break;
        }

    }while(opcion != 8);
}

// ================= MAIN =================
int main(){

    int tipo;

    cout << "--- SELECCION DE TIPO DE DATO ---\n";
    cout << "1. Enteros\n";
    cout << "2. Strings\n";
    cout << "Opcion: ";
    cin >> tipo;

    if(tipo == 1){
        menuLista<int>();
    }
    else if(tipo == 2){
        menuLista<string>();
    }
    else{
        cout << "Opcion invalida\n";
    }

    return 0;
}
